# Configuracion de Base de Datos (MySQL/XAMPP)
DB_HOST=localhost
DB_NAME=villalobos_logistica_2
DB_USER=root
DB_PASS=

# Configuracion SMTP (Mailtrap sandbox o SMTP real en produccion)
# Sustituir por credenciales reales en .env (NUNCA commitear)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_USER=YOUR_SMTP_USER
SMTP_PASS=YOUR_SMTP_PASS
SMTP_PORT=2525
SMTP_FROM_EMAIL=no-reply@villaloboslogistica.com
SMTP_FROM_NAME="Web Villalobos Logistica"
SMTP_TO_EMAIL=info@villaloboslogistica.com